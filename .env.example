# TiDB Cloud Starter connection settings.
# The created instance for this lab is:
#   name: agent-memory-lab
#   region: Singapore (ap-southeast-1)
#   spending limit: $0/month
#
# Get exact values from TiDB Cloud > agent-memory-lab > Connect.
TIDB_HOST=gateway01.ap-southeast-1.prod.aws.tidbcloud.com
TIDB_PORT=4000
TIDB_USER=<prefix>.root
TIDB_PASSWORD=<password>
TIDB_DATABASE=agent_memory_lab

# Public TiDB Cloud Starter connections require TLS.
TIDB_SSL_CA=/etc/ssl/cert.pem

# Optional runtime selector. Use "local" for offline verification.
MEMORY_STORE=tidb
